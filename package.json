{
  "name": "dialog-dev",
  "version": "0.1.1",
  "description": "Local-first AI-powered log analysis tool with CLI and web dashboard",
  "type": "module",
  "main": "./dist/cli-entry.js",
  "bin": {
    "dialog-cli": "dist/cli-entry.js",
    "dialog-web": "dist/web-entry.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "mcp-config.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev:cli": "tsx src/cli-entry.ts",
    "dev:web": "tsx src/web-entry.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "logs",
    "debugging",
    "ai",
    "cli",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "chromadb": "^3.4.0",
    "commander": "^14.0.3",
    "duckdb": "^1.4.4",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "toml": "^3.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-notifier": "^8.0.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
